# Virtual environment — recreated by setup.bat
venv/

# Regenerated by setup.bat every run — bakes in an absolute, machine-
# specific path, so it shouldn't be committed
launch.bat

# Embedded Python runtime — downloaded by setup.bat when no compatible
# system Python is found. Machine-specific, ~100 MB+, redownloadable.
python312/

# Claude Code local settings (machine-specific permissions, not shared)
.claude/

# Chat history (stored outside repo in ~/.desktop_agent/)
history/

# Python cache
__pycache__/
*.py[cod]
*.pyo

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Logs and temp
*.log
*.tmp
